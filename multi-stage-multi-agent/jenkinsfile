pipeline {
    agent none

    stages {
        stage('Back-end') {
            agent {
                docker {
                    image 'maven:3.9.4-eclipse-temurin-21-alpine'
                }
            }
            steps {
                sh '''
                    mkdir -p .m2
                    mvn -Dmaven.repo.local=.m2/repository clean package
                '''
            }
        }

        stage('Front-end') {
            agent {
                docker {
                    image 'node:16-alpine'
                }
            }
            steps {
                sh 'npm install'
                sh 'npm run build'
            }
        }
    }
}
